# Server
HOST=0.0.0.0
PORT=8080
SELF_URL=https://example.mctai.app

# PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/database

# Object storage
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key
OBJECT_STORAGE_PREFIX=app-prefix

# Platform auth
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_replace-with-token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Platform email proxy
MCTAI_EMAIL_URL=https://email.example.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=replace-with-email-token
MCTAI_EMAIL_SENDER_NAME=App Notifications

# Frontend public config
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_BASE_URL=http://localhost:5173
