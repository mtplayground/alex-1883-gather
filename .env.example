# Server
HOST=0.0.0.0
PORT=8080
SELF_URL=https://example.mctai.app

# PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/database

# Object storage
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key
OBJECT_STORAGE_PREFIX=app-prefix

# Platform auth
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_alex-1883-gather-f41811
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Platform email proxy (optional; leave blank to skip email delivery gracefully)
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=
MCTAI_EMAIL_SENDER_NAME=alex-1883-gather-notifications

# Frontend public config (set before building frontend/dist)
VITE_API_BASE_URL=https://api.example.mctai.app
VITE_APP_BASE_URL=https://example.mctai.app
VITE_MCTAI_AUTH_URL=https://auth.mctai.app
VITE_MCTAI_AUTH_APP_TOKEN=app_alex-1883-gather-f41811
