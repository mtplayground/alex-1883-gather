{
  "name": "alex-1883-gather",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:backend": "cargo run -p alex-1883-gather-backend",
    "dev:frontend": "npm --workspace frontend run dev",
    "db:migrate": "cargo run -p alex-1883-gather-backend --bin migrate",
    "build": "npm --workspace frontend run build && cargo build",
    "lint": "npm --workspace frontend run lint && cargo fmt --all --check",
    "format": "prettier --write . && cargo fmt --all"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
